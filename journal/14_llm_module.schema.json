{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Timezone Bot — LLM Module Output (v2.0)",
  "type": "object",
  "additionalProperties": false,
  "required": ["reflections", "event", "sender_id", "sender_name", "points"],
  "properties": {
    "reflections": {
      "type": "object",
      "description": "Chain-of-thought reasoning block (not shown to users).",
      "required": ["event_logic", "time_logic", "geo_logic"],
      "properties": {
        "event_logic": { "type": "string" },
        "time_logic":  { "type": "string" },
        "geo_logic":   { "type": "string" }
      },
      "additionalProperties": false
    },
    "event": {
      "type": "boolean",
      "description": "true = actionable time-coordination event; LLM should call convert_time tool"
    },
    "sender_id": {
      "type": "string",
      "description": "Platform user ID echoed from SENDER block; passed through to convert_time tool"
    },
    "sender_name": {
      "type": "string",
      "description": "Display name echoed from SENDER block; used in formatted reply"
    },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time", "city", "event_type"],
        "properties": {
          "time": { "type": "string", "description": "24h format HH:MM" },
          "city": { "type": ["string", "null"], "description": "City name OR null" },
          "event_type": { "type": "string", "description": "Type of event, e.g. 'meeting', 'call', 'deadline'" }
        }
      },
      "description": "List of extracted time points with their respective locations."
    }
  }
}
